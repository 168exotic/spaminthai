{
  "name": "spaminthai",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev . --kv SPAM_KV --port 8788 --persist-to /tmp/wrangler-state",
    "deploy": "wrangler pages deploy . --project-name spaminthai",
    "verify-token": "node scripts/verify-token.js",
    "seed": "node scripts/seed-spam-numbers.js data/spam-numbers-sample.json",
    "test": "node scripts/test-assess.mjs && node scripts/test-carrier.mjs",
    "release:weekly": "node scripts/prepare-weekly-release.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
