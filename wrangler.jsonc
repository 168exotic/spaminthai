{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spaminthai",
  "main": "_worker.js",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "kv_namespaces": [
    {
      "binding": "SPAM_KV",
      "id": "d1417790ca5841bebf80cbc25443e070"
    }
  ],
  "r2_buckets": [
    {
      "binding": "EVIDENCE_R2",
      "bucket_name": "spaminthai-evidence"
    }
  ]
}
