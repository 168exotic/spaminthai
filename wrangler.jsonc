{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spaminthai-web",
  "main": "_worker.js",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "kv_namespaces": [
    {
      "binding": "SPAM_KV",
      "id": "0a479fd6d75c431b8e7018caf819f7b2"
    }
  ]
}
